# Copy this file to `.env` and fill in your own values:
#   cp .env.example .env
# `.env` is git-ignored — never commit your real token.

# ─── Discord ────────────────────────────────────────────────────────────────
# Bot token from the Developer Portal (Bot tab → Reset Token).
# Treat this like a password. If it ever leaks, reset it immediately.
DISCORD_TOKEN=your-discord-bot-token-here

# Optional but recommended while developing: your test server's ID.
# Slash commands sync INSTANTLY to this guild (global sync can take ~1 hour).
# Right-click your server icon → Copy Server ID (needs Developer Mode on).
DEV_GUILD_ID=your-dev-server-id-here

# ─── AWS / DynamoDB ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
PET_TABLE=ServerPet

# Local development with DynamoDB Local (uncomment after starting it):
#   docker run -p 8000:8000 amazon/dynamodb-local
# DYNAMODB_ENDPOINT=http://localhost:8000

# ─── Production only (instead of DISCORD_TOKEN) ─────────────────────────────
# Store the token in SSM Parameter Store as a SecureString and reference it:
# DISCORD_TOKEN_PARAM=/server-pet/discord-token
